{
  "name": "Inference CNN on MNIST",
  "description": "Load a trained CNN model (from TrainCNN-MNIST example) and run inference on a single image. SequentialModel rebuilds the same architecture, ModelLoader restores the saved weights, ImageReader loads a test image, and Inference runs the forward pass to produce a prediction.",
  "nodes": [
    {
      "id": "model-builder",
      "type": "SequentialModel",
      "position": { "x": 50, "y": 200 },
      "data": {
        "params": {
          "layers": "[{\"type\":\"Conv2d\",\"in_channels\":1,\"out_channels\":32,\"kernel_size\":3,\"padding\":1},{\"type\":\"ReLU\"},{\"type\":\"MaxPool2d\",\"kernel_size\":2,\"stride\":2},{\"type\":\"Conv2d\",\"in_channels\":32,\"out_channels\":64,\"kernel_size\":3,\"padding\":1},{\"type\":\"ReLU\"},{\"type\":\"MaxPool2d\",\"kernel_size\":2,\"stride\":2},{\"type\":\"Flatten\"},{\"type\":\"Linear\",\"in_features\":3136,\"out_features\":128},{\"type\":\"ReLU\"},{\"type\":\"Linear\",\"in_features\":128,\"out_features\":10}]"
        }
      }
    },
    {
      "id": "weight-loader",
      "type": "ModelLoader",
      "position": { "x": 450, "y": 200 },
      "data": {
        "params": {
          "path": "model_weights.pt",
          "load_mode": "state_dict",
          "device": "cpu",
          "strict": true
        }
      }
    },
    {
      "id": "test-image",
      "type": "ImageReader",
      "position": { "x": 450, "y": 420 },
      "data": {
        "params": {
          "path": "test_digit.png",
          "mode": "grayscale",
          "resize": 28
        }
      }
    },
    {
      "id": "add-batch-dim",
      "type": "Unsqueeze",
      "position": { "x": 650, "y": 420 },
      "data": { "params": { "dim": 0 } }
    },
    {
      "id": "inference",
      "type": "Inference",
      "position": { "x": 850, "y": 280 },
      "data": {
        "params": {
          "device": "cpu"
        }
      }
    },
    {
      "id": "print-output",
      "type": "Print",
      "position": { "x": 1200, "y": 200 },
      "data": { "params": { "label": "Raw logits (10 classes)" } }
    },
    {
      "id": "softmax",
      "type": "Softmax",
      "position": { "x": 1200, "y": 380 },
      "data": { "params": { "dim": -1 } }
    },
    {
      "id": "print-probs",
      "type": "Print",
      "position": { "x": 1550, "y": 380 },
      "data": { "params": { "label": "Prediction probabilities" } }
    }
  ],
  "edges": [
    { "id": "e-1", "source": "model-builder", "target": "weight-loader", "sourceHandle": "model", "targetHandle": "model" },
    { "id": "e-2", "source": "weight-loader", "target": "inference", "sourceHandle": "model", "targetHandle": "model" },
    { "id": "e-3", "source": "test-image", "target": "add-batch-dim", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-3b", "source": "add-batch-dim", "target": "inference", "sourceHandle": "tensor", "targetHandle": "input" },
    { "id": "e-4", "source": "inference", "target": "print-output", "sourceHandle": "output", "targetHandle": "value" },
    { "id": "e-5", "source": "inference", "target": "softmax", "sourceHandle": "output", "targetHandle": "tensor" },
    { "id": "e-6", "source": "softmax", "target": "print-probs", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
