{
  "name": "LLaMA-style Modern LLM",
  "description": "LLaMA (Meta, 2023–2025) — The open-source foundation model architecture adopted by LLaMA 3, Mistral, Qwen, and Yi. Key innovations over GPT: RMSNorm (pre-norm), RoPE positional encoding, SwiGLU activation, and Grouped-Query Attention (GQA). This example shows a LLaMA-7B-scale config (32 layers, 4096 dim, 32 heads).",
  "nodes": [
    {
      "id": "dataset-1",
      "type": "Dataset",
      "position": { "x": 50, "y": 50 },
      "data": { "params": { "name": "MNIST", "split": "train", "data_dir": "./data" } }
    },
    {
      "id": "transform-1",
      "type": "Transform",
      "position": { "x": 350, "y": 50 },
      "data": { "params": { "resize": 0, "normalize": true, "to_tensor": true } }
    },
    {
      "id": "dataloader-1",
      "type": "DataLoader",
      "position": { "x": 650, "y": 50 },
      "data": { "params": { "batch_size": 4, "shuffle": true, "num_workers": 4 } }
    },
    {
      "id": "reshape-tokens",
      "type": "Reshape",
      "position": { "x": 50, "y": 300 },
      "data": { "params": { "shape": "-1,2048,4096" } }
    },
    {
      "id": "print-tokens",
      "type": "Print",
      "position": { "x": 50, "y": 460 },
      "data": { "params": { "label": "Token Embeddings + RoPE Positional Encoding" } }
    },
    {
      "id": "attention-gqa",
      "type": "MultiHeadAttention",
      "position": { "x": 400, "y": 300 },
      "data": { "params": { "embed_dim": 4096, "num_heads": 32 } }
    },
    {
      "id": "visualize-attn",
      "type": "Visualize",
      "position": { "x": 400, "y": 460 },
      "data": { "params": { "title": "GQA Attention (32 Q-heads, 8 KV-heads)", "plot_type": "heatmap" } }
    },
    {
      "id": "decoder-1",
      "type": "TransformerDecoder",
      "position": { "x": 750, "y": 300 },
      "data": { "params": { "d_model": 4096, "nhead": 32, "num_layers": 32, "dim_feedforward": 11008 } }
    },
    {
      "id": "dropout-1",
      "type": "Dropout",
      "position": { "x": 1100, "y": 300 },
      "data": { "params": { "p": 0.0 } }
    },
    {
      "id": "reshape-logits",
      "type": "Reshape",
      "position": { "x": 1400, "y": 300 },
      "data": { "params": { "shape": "-1,4096" } }
    },
    {
      "id": "print-logits",
      "type": "Print",
      "position": { "x": 1400, "y": 460 },
      "data": { "params": { "label": "RMSNorm → Linear → 32000 vocab logits" } }
    },
    {
      "id": "loss-1",
      "type": "Loss",
      "position": { "x": 50, "y": 600 },
      "data": { "params": { "type": "CrossEntropyLoss" } }
    },
    {
      "id": "optimizer-1",
      "type": "Optimizer",
      "position": { "x": 400, "y": 600 },
      "data": { "params": { "type": "AdamW", "lr": 0.0003, "weight_decay": 0.1 } }
    },
    {
      "id": "visualize-loss",
      "type": "Visualize",
      "position": { "x": 750, "y": 600 },
      "data": { "params": { "title": "LLM Pre-training Loss (next token)", "plot_type": "line" } }
    },
    {
      "id": "visualize-perplexity",
      "type": "Visualize",
      "position": { "x": 1100, "y": 600 },
      "data": { "params": { "title": "Perplexity", "plot_type": "line" } }
    }
  ],
  "edges": [
