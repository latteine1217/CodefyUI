{
  "name": "BiGRU Speech Feature Extractor",
  "description": "Bidirectional GRU for Speech Recognition — Processes audio mel-spectrogram features in both forward and backward directions. BiGRU is widely used as the acoustic model backbone in modern ASR (Automatic Speech Recognition) systems like DeepSpeech and Conformer. Captures temporal context from both past and future frames.",
  "nodes": [
    {
      "id": "dataset-1",
      "type": "Dataset",
      "position": { "x": 50, "y": 50 },
      "data": { "params": { "name": "MNIST", "split": "train", "data_dir": "./data" } }
    },
    {
      "id": "transform-1",
      "type": "Transform",
      "position": { "x": 350, "y": 50 },
      "data": { "params": { "resize": 0, "normalize": true, "to_tensor": true } }
    },
    {
      "id": "dataloader-1",
      "type": "DataLoader",
      "position": { "x": 650, "y": 50 },
      "data": { "params": { "batch_size": 32, "shuffle": true, "num_workers": 2 } }
    },
    {
      "id": "reshape-mel",
      "type": "Reshape",
      "position": { "x": 50, "y": 280 },
      "data": { "params": { "shape": "-1,100,80" } }
    },
    {
      "id": "print-mel",
      "type": "Print",
      "position": { "x": 50, "y": 440 },
      "data": { "params": { "label": "Input: Mel-Spectrogram (100 frames × 80 mel bins)" } }
    },
    {
      "id": "bigru-1",
      "type": "GRU",
      "position": { "x": 400, "y": 280 },
      "data": { "params": { "input_size": 80, "hidden_size": 256, "num_layers": 3, "batch_first": true, "bidirectional": true } }
    },
    {
      "id": "dropout-1",
      "type": "Dropout",
      "position": { "x": 750, "y": 280 },
      "data": { "params": { "p": 0.3 } }
    },
    {
      "id": "bigru-2",
      "type": "GRU",
      "position": { "x": 1100, "y": 280 },
      "data": { "params": { "input_size": 512, "hidden_size": 256, "num_layers": 2, "batch_first": true, "bidirectional": true } }
    },
    {
      "id": "dropout-2",
      "type": "Dropout",
      "position": { "x": 1100, "y": 440 },
      "data": { "params": { "p": 0.2 } }
    },
    {
      "id": "reshape-out",
      "type": "Reshape",
      "position": { "x": 1100, "y": 600 },
      "data": { "params": { "shape": "-1,512" } }
    },
    {
      "id": "print-ctc",
      "type": "Print",
      "position": { "x": 1400, "y": 600 },
      "data": { "params": { "label": "CTC Output: character probabilities per frame" } }
    },
    {
      "id": "visualize-hidden",
      "type": "Visualize",
      "position": { "x": 750, "y": 440 },
      "data": { "params": { "title": "BiGRU Hidden States", "plot_type": "heatmap" } }
    },
    {
      "id": "loss-1",
      "type": "Loss",
      "position": { "x": 50, "y": 600 },
      "data": { "params": { "type": "CrossEntropyLoss" } }
    },
    {
      "id": "optimizer-1",
      "type": "Optimizer",
      "position": { "x": 400, "y": 600 },
      "data": { "params": { "type": "Adam", "lr": 0.0003, "weight_decay": 0.0 } }
    },
    {
      "id": "visualize-loss",
      "type": "Visualize",
      "position": { "x": 400, "y": 440 },
      "data": { "params": { "title": "CTC Loss", "plot_type": "line" } }
    }
  ],
  "edges": [
    { "id": "e-1", "source": "dataset-1", "target": "transform-1", "sourceHandle": "dataset", "targetHandle": "dataset" },
    { "id": "e-2", "source": "transform-1", "target": "dataloader-1", "sourceHandle": "dataset", "targetHandle": "dataset" },
    { "id": "e-3", "source": "reshape-mel", "target": "bigru-1", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-4", "source": "reshape-mel", "target": "print-mel", "sourceHandle": "tensor", "targetHandle": "value" },
    { "id": "e-5", "source": "bigru-1", "target": "dropout-1", "sourceHandle": "output", "targetHandle": "tensor" },
    { "id": "e-6", "source": "dropout-1", "target": "bigru-2", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-7", "source": "bigru-1", "target": "visualize-hidden", "sourceHandle": "hidden", "targetHandle": "data" },
    { "id": "e-8", "source": "bigru-2", "target": "dropout-2", "sourceHandle": "output", "targetHandle": "tensor" },
    { "id": "e-9", "source": "dropout-2", "target": "reshape-out", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-10", "source": "reshape-out", "target": "print-ctc", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
