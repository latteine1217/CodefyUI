{
  "name": "Vision Transformer (ViT)",
  "description": "Vision Transformer (Google, 2020) — 'An Image is Worth 16x16 Words'. Splits images into 16×16 patches via Conv2d (acting as patch embedding), then processes the patch sequence with a Transformer Encoder. Demonstrated that pure Transformers can match or outperform CNNs on image classification when pre-trained on large datasets.",
  "nodes": [
    {
      "id": "dataset-1",
      "type": "Dataset",
      "position": {
        "x": 50,
        "y": 50
      },
      "data": {
        "params": {
          "name": "CIFAR10",
          "split": "train",
          "data_dir": "./data"
        },
        "isEntryPoint": true
      }
    },
    {
      "id": "transform-1",
      "type": "Transform",
      "position": {
        "x": 400,
        "y": 50
      },
      "data": {
        "params": {
          "resize": 224,
          "normalize": true,
          "to_tensor": true
        }
      }
    },
    {
      "id": "dataloader-1",
      "type": "DataLoader",
      "position": {
        "x": 750,
        "y": 50
      },
      "data": {
        "params": {
          "batch_size": 64,
          "shuffle": true,
          "num_workers": 4
        }
      }
    },
    {
      "id": "patch-embed",
      "type": "Conv2d",
      "position": {
        "x": 50,
        "y": 300
      },
      "data": {
        "params": {
          "in_channels": 3,
          "out_channels": 768,
          "kernel_size": 16,
          "stride": 16,
          "padding": 0
        },
        "isEntryPoint": true
      }
    },
    {
      "id": "reshape-seq",
      "type": "Reshape",
      "position": {
        "x": 750,
        "y": 300
      },
      "data": {
        "params": {
          "shape": "-1,196,768"
        }
      }
    },
    {
      "id": "encoder-1",
      "type": "TransformerEncoder",
      "position": {
        "x": 50,
        "y": 500
      },
      "data": {
        "params": {
          "d_model": 768,
          "nhead": 12,
          "num_layers": 12,
          "dim_feedforward": 3072
        }
      }
    },
    {
      "id": "dropout-1",
      "type": "Dropout",
      "position": {
        "x": 400,
        "y": 500
      },
      "data": {
        "params": {
          "p": 0.1
        }
      }
    },
    {
      "id": "reshape-cls",
      "type": "Reshape",
      "position": {
        "x": 750,
        "y": 500
      },
      "data": {
        "params": {
          "shape": "-1,768"
        }
      }
    },
    {
      "id": "print-patches",
      "type": "Print",
      "position": {
        "x": 50,
        "y": 700
      },
      "data": {
        "params": {
          "label": "Patch Embeddings (196 patches × 768 dim)"
        }
      }
    },
    {
      "id": "print-cls",
      "type": "Print",
      "position": {
        "x": 400,
        "y": 700
      },
      "data": {
        "params": {
          "label": "CLS Token → Classification Head"
        }
      }
    },
    {
      "id": "loss-1",
      "type": "Loss",
      "position": {
        "x": 50,
        "y": 950
      },
      "data": {
        "params": {
          "type": "CrossEntropyLoss"
        },
        "isEntryPoint": true
      }
    },
