      "data": {
        "params": {
          "layers": "{\"version\": 2, \"nodes\": [{\"id\": \"in\", \"type\": \"Input\", \"ports\": [{\"id\": \"p_x\", \"name\": \"x\"}]}, {\"id\": \"n0\", \"type\": \"Conv2d\", \"params\": {\"in_channels\": 3, \"out_channels\": 768, \"kernel_size\": 16, \"stride\": 16}}, {\"id\": \"n1\", \"type\": \"Reshape\", \"params\": {\"shape\": \"196,768\"}}, {\"id\": \"n2\", \"type\": \"TransformerEncoder\", \"params\": {\"d_model\": 768, \"nhead\": 12, \"num_layers\": 12, \"dim_feedforward\": 3072}}, {\"id\": \"n3\", \"type\": \"SelectIndex\", \"params\": {\"dim\": 1, \"index\": 0}}, {\"id\": \"n4\", \"type\": \"Dropout\", \"params\": {\"p\": 0.1}}, {\"id\": \"n5\", \"type\": \"Linear\", \"params\": {\"in_features\": 768, \"out_features\": 10}}, {\"id\": \"out\", \"type\": \"Output\", \"ports\": [{\"id\": \"p_y\", \"name\": \"y\"}]}], \"edges\": [{\"id\": \"e0\", \"source\": \"in\", \"sourceHandle\": \"p_x\", \"target\": \"n0\"}, {\"id\": \"e1\", \"source\": \"n0\", \"target\": \"n1\"}, {\"id\": \"e2\", \"source\": \"n1\", \"target\": \"n2\"}, {\"id\": \"e3\", \"source\": \"n2\", \"target\": \"n3\"}, {\"id\": \"e4\", \"source\": \"n3\", \"target\": \"n4\"}, {\"id\": \"e5\", \"source\": \"n4\", \"target\": \"n5\"}, {\"id\": \"e6\", \"source\": \"n5\", \"target\": \"out\", \"targetHandle\": \"p_y\"}]}"
        },
        "isEntryPoint": true
      }
    },
