{
  "name": "ViT Image Classifier (Transformer)",
  "description": "Forward-pass visualization of a Vision Transformer. A (2,3,32,32) image batch is sliced into 8x8 non-overlapping patches by a Conv2d stem (stride=8), producing a (2,48,4,4) tensor. Reshape+Permute flatten the spatial grid into a 16-token sequence of 48-dim embeddings (seq=16, batch=2, d=48). A TransformerEncoder applies self-attention across all patches globally. We mean-pool the patch tokens and project to 10 class logits.",
  "nodes": [
    { "id": "start-1", "type": "Start", "position": { "x": -200, "y": 0 }, "data": { "params": {} } },
    { "id": "input", "type": "TensorCreate", "position": { "x": 0, "y": 0 }, "data": { "params": { "shape": "2,3,32,32", "fill": "randn", "value": 0.0, "requires_grad": false } } },
    { "id": "patch_embed", "type": "Conv2d", "position": { "x": 220, "y": 0 }, "data": { "params": { "in_channels": 3, "out_channels": 48, "kernel_size": 8, "stride": 8, "padding": 0 } } },
    { "id": "flatten_patches", "type": "Reshape", "position": { "x": 440, "y": 0 }, "data": { "params": { "shape": "2,48,16" } } },
    { "id": "to_seq_first", "type": "Permute", "position": { "x": 660, "y": 0 }, "data": { "params": { "dims": "2,0,1" } } },
    { "id": "encoder", "type": "TransformerEncoder", "position": { "x": 920, "y": 0 }, "data": { "params": { "d_model": 48, "nhead": 4, "num_layers": 4, "dim_feedforward": 192 } } },
    { "id": "to_batch_first", "type": "Permute", "position": { "x": 1200, "y": 0 }, "data": { "params": { "dims": "1,0,2" } } },
    { "id": "pool", "type": "Mean", "position": { "x": 1420, "y": 0 }, "data": { "params": { "dim": "1", "keepdim": false } } },
    { "id": "head", "type": "Linear", "position": { "x": 1640, "y": 0 }, "data": { "params": { "in_features": 48, "out_features": 10 } } },
    { "id": "print_logits", "type": "Print", "position": { "x": 1860, "y": 0 }, "data": { "params": { "label": "Class logits (B,10)" } } }
  ],
  "edges": [
    { "id": "e-t", "source": "start-1", "target": "input", "sourceHandle": "trigger", "type": "trigger" },
    { "id": "e1", "source": "input", "target": "patch_embed", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e2", "source": "patch_embed", "target": "flatten_patches", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e3", "source": "flatten_patches", "target": "to_seq_first", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e4", "source": "to_seq_first", "target": "encoder", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e5", "source": "encoder", "target": "to_batch_first", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e6", "source": "to_batch_first", "target": "pool", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e7", "source": "pool", "target": "head", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e8", "source": "head", "target": "print_logits", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
