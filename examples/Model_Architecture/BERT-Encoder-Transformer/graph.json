{
  "name": "BERT Encoder Transformer",
  "description": "Forward-pass visualization of a BERT-style bidirectional encoder on a (seq=16, batch=2, d=48) token-embedding tensor. Unlike GPT (decoder, causal self-attention), BERT uses the full TransformerEncoder stack where each token can attend to every other token. We pool the sequence with a Mean over the sequence dimension and project to two classification logits, analogous to a CLS-head classifier.",
  "nodes": [
    { "id": "start-1", "type": "Start", "position": { "x": -200, "y": 0 }, "data": { "params": {} } },
    { "id": "input", "type": "TensorCreate", "position": { "x": 0, "y": 0 }, "data": { "params": { "shape": "16,2,48", "fill": "randn", "value": 0.0, "requires_grad": false } } },
    { "id": "encoder", "type": "TransformerEncoder", "position": { "x": 260, "y": 0 }, "data": { "params": { "d_model": 48, "nhead": 4, "num_layers": 4, "dim_feedforward": 192 } } },
    { "id": "to_batch_first", "type": "Permute", "position": { "x": 540, "y": 0 }, "data": { "params": { "dims": "1,0,2" } } },
    { "id": "pool", "type": "Mean", "position": { "x": 760, "y": 0 }, "data": { "params": { "dim": "1", "keepdim": false } } },
    { "id": "head", "type": "Linear", "position": { "x": 980, "y": 0 }, "data": { "params": { "in_features": 48, "out_features": 2 } } },
    { "id": "print_logits", "type": "Print", "position": { "x": 1200, "y": 0 }, "data": { "params": { "label": "CLS logits (B,2)" } } }
  ],
  "edges": [
    { "id": "e-t", "source": "start-1", "target": "input", "sourceHandle": "trigger", "type": "trigger" },
    { "id": "e1", "source": "input", "target": "encoder", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e2", "source": "encoder", "target": "to_batch_first", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e3", "source": "to_batch_first", "target": "pool", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e4", "source": "pool", "target": "head", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e5", "source": "head", "target": "print_logits", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
