{
  "name": "Swin Transformer (Simplified)",
  "description": "Forward-pass visualization of a simplified Swin Transformer stage. Swin's distinctive idea is hierarchical patch merging + shifted-window attention for linear-in-pixels complexity. This demo keeps the hierarchy and patch embedding (Conv2d stride=4 then a second stride=2 downsample) but uses a plain TransformerEncoder at each stage rather than shifted-window attention (which requires cycle-shift ops not yet available as canvas primitives). Output is 10 class logits from mean-pooled patches.",
  "nodes": [
    { "id": "start-1", "type": "Start", "position": { "x": -200, "y": 0 }, "data": { "params": {} } },
    { "id": "input", "type": "TensorCreate", "position": { "x": 0, "y": 0 }, "data": { "params": { "shape": "2,3,32,32", "fill": "randn", "value": 0.0, "requires_grad": false } } },
    { "id": "patch_embed", "type": "Conv2d", "position": { "x": 220, "y": 0 }, "data": { "params": { "in_channels": 3, "out_channels": 48, "kernel_size": 4, "stride": 4, "padding": 0 } } },
    { "id": "stage1_flat", "type": "Reshape", "position": { "x": 440, "y": 0 }, "data": { "params": { "shape": "2,48,64" } } },
    { "id": "stage1_seq", "type": "Permute", "position": { "x": 660, "y": 0 }, "data": { "params": { "dims": "2,0,1" } } },
    { "id": "stage1_enc", "type": "TransformerEncoder", "position": { "x": 920, "y": 0 }, "data": { "params": { "d_model": 48, "nhead": 4, "num_layers": 2, "dim_feedforward": 192 } } },
    { "id": "stage1_bf", "type": "Permute", "position": { "x": 1200, "y": 0 }, "data": { "params": { "dims": "1,2,0" } } },
    { "id": "stage1_grid", "type": "Reshape", "position": { "x": 1420, "y": 0 }, "data": { "params": { "shape": "2,48,8,8" } } },

    { "id": "merge", "type": "Conv2d", "position": { "x": 0, "y": 260 }, "data": { "params": { "in_channels": 48, "out_channels": 96, "kernel_size": 2, "stride": 2, "padding": 0 } } },
    { "id": "stage2_flat", "type": "Reshape", "position": { "x": 220, "y": 260 }, "data": { "params": { "shape": "2,96,16" } } },
    { "id": "stage2_seq", "type": "Permute", "position": { "x": 440, "y": 260 }, "data": { "params": { "dims": "2,0,1" } } },
    { "id": "stage2_enc", "type": "TransformerEncoder", "position": { "x": 700, "y": 260 }, "data": { "params": { "d_model": 96, "nhead": 4, "num_layers": 2, "dim_feedforward": 384 } } },
    { "id": "stage2_bf", "type": "Permute", "position": { "x": 980, "y": 260 }, "data": { "params": { "dims": "1,0,2" } } },
    { "id": "pool", "type": "Mean", "position": { "x": 1200, "y": 260 }, "data": { "params": { "dim": "1", "keepdim": false } } },
    { "id": "head", "type": "Linear", "position": { "x": 1420, "y": 260 }, "data": { "params": { "in_features": 96, "out_features": 10 } } },
    { "id": "print_logits", "type": "Print", "position": { "x": 1640, "y": 260 }, "data": { "params": { "label": "Class logits (B,10)" } } }
  ],
  "edges": [
    { "id": "e-t", "source": "start-1", "target": "input", "sourceHandle": "trigger", "type": "trigger" },
    { "id": "e1", "source": "input", "target": "patch_embed", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e2", "source": "patch_embed", "target": "stage1_flat", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e3", "source": "stage1_flat", "target": "stage1_seq", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e4", "source": "stage1_seq", "target": "stage1_enc", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e5", "source": "stage1_enc", "target": "stage1_bf", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e6", "source": "stage1_bf", "target": "stage1_grid", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e7", "source": "stage1_grid", "target": "merge", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e8", "source": "merge", "target": "stage2_flat", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e9", "source": "stage2_flat", "target": "stage2_seq", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e10", "source": "stage2_seq", "target": "stage2_enc", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e11", "source": "stage2_enc", "target": "stage2_bf", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e12", "source": "stage2_bf", "target": "pool", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e13", "source": "pool", "target": "head", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e14", "source": "head", "target": "print_logits", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
