      "position": { "x": 50, "y": 780 },
      "data": { "params": { "in_channels": 192, "out_channels": 384, "kernel_size": 2, "stride": 2, "padding": 0 } }
    },
    {
      "id": "reshape-s3",
      "type": "Reshape",
      "position": { "x": 350, "y": 780 },
      "data": { "params": { "shape": "-1,196,384" } }
    },
    {
      "id": "stage3-encoder",
