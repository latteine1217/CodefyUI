{
  "name": "EfficientNet MBConv Block (Simplified)",
  "description": "Forward-pass visualization of EfficientNet's core MBConv (mobile inverted bottleneck) block. The expand→depthwise-spatial→squeeze-and-excite→project pattern is simplified here: (1) expand via 1x1 Conv (channels 32→128), (2) spatial mixing via 3x3 Conv, (3) Squeeze-and-Excite via AdaptiveAvgPool→Linear→Linear→sigmoid→Multiply, (4) project back via 1x1 Conv, (5) residual Add. Input (2,32,16,16) → MBConv block → (2,32,16,16) → global pool → Linear → 10 class logits.",
  "nodes": [
    { "id": "start-1", "type": "Start", "position": { "x": -200, "y": 0 }, "data": { "params": {} } },
    { "id": "input", "type": "TensorCreate", "position": { "x": 0, "y": 0 }, "data": { "params": { "shape": "2,32,16,16", "fill": "randn", "value": 0.0, "requires_grad": false } } },

    { "id": "expand", "type": "Conv2d", "position": { "x": 220, "y": 0 }, "data": { "params": { "in_channels": 32, "out_channels": 128, "kernel_size": 1, "stride": 1, "padding": 0 } } },
    { "id": "expand_bn", "type": "BatchNorm2d", "position": { "x": 440, "y": 0 }, "data": { "params": { "num_features": 128 } } },
    { "id": "expand_act", "type": "Activation", "position": { "x": 660, "y": 0 }, "data": { "params": { "function": "silu" } } },

    { "id": "spatial", "type": "Conv2d", "position": { "x": 880, "y": 0 }, "data": { "params": { "in_channels": 128, "out_channels": 128, "kernel_size": 3, "stride": 1, "padding": 1 } } },
    { "id": "spatial_bn", "type": "BatchNorm2d", "position": { "x": 1100, "y": 0 }, "data": { "params": { "num_features": 128 } } },
    { "id": "spatial_act", "type": "Activation", "position": { "x": 1320, "y": 0 }, "data": { "params": { "function": "silu" } } },

    { "id": "se_pool", "type": "AdaptiveAvgPool2d", "position": { "x": 0, "y": 260 }, "data": { "params": { "output_height": 1, "output_width": 1 } } },
    { "id": "se_flat", "type": "Flatten", "position": { "x": 220, "y": 260 }, "data": { "params": { "start_dim": 1 } } },
    { "id": "se_reduce", "type": "Linear", "position": { "x": 440, "y": 260 }, "data": { "params": { "in_features": 128, "out_features": 8 } } },
    { "id": "se_act", "type": "Activation", "position": { "x": 660, "y": 260 }, "data": { "params": { "function": "silu" } } },
    { "id": "se_expand", "type": "Linear", "position": { "x": 880, "y": 260 }, "data": { "params": { "in_features": 8, "out_features": 128 } } },
    { "id": "se_sigmoid", "type": "Activation", "position": { "x": 1100, "y": 260 }, "data": { "params": { "function": "sigmoid" } } },
    { "id": "se_unflat", "type": "Reshape", "position": { "x": 1320, "y": 260 }, "data": { "params": { "shape": "2,128,1,1" } } },
    { "id": "se_apply", "type": "Multiply", "position": { "x": 1540, "y": 130 }, "data": { "params": { "alpha": 1.0 } } },

    { "id": "project", "type": "Conv2d", "position": { "x": 1760, "y": 130 }, "data": { "params": { "in_channels": 128, "out_channels": 32, "kernel_size": 1, "stride": 1, "padding": 0 } } },
    { "id": "project_bn", "type": "BatchNorm2d", "position": { "x": 1980, "y": 130 }, "data": { "params": { "num_features": 32 } } },
    { "id": "skip_add", "type": "Add", "position": { "x": 2200, "y": 130 }, "data": { "params": { "alpha": 1.0 } } },

    { "id": "head_pool", "type": "AdaptiveAvgPool2d", "position": { "x": 0, "y": 520 }, "data": { "params": { "output_height": 1, "output_width": 1 } } },
    { "id": "head_flat", "type": "Flatten", "position": { "x": 220, "y": 520 }, "data": { "params": { "start_dim": 1 } } },
    { "id": "head_fc", "type": "Linear", "position": { "x": 440, "y": 520 }, "data": { "params": { "in_features": 32, "out_features": 10 } } },
    { "id": "print_logits", "type": "Print", "position": { "x": 660, "y": 520 }, "data": { "params": { "label": "Class logits (B,10)" } } }
  ],
  "edges": [
    { "id": "e-t", "source": "start-1", "target": "input", "sourceHandle": "trigger", "type": "trigger" },

    { "id": "e1", "source": "input", "target": "expand", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e2", "source": "expand", "target": "expand_bn", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e3", "source": "expand_bn", "target": "expand_act", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e4", "source": "expand_act", "target": "spatial", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e5", "source": "spatial", "target": "spatial_bn", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e6", "source": "spatial_bn", "target": "spatial_act", "sourceHandle": "tensor", "targetHandle": "tensor" },

    { "id": "e7", "source": "spatial_act", "target": "se_pool", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e8", "source": "se_pool", "target": "se_flat", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e9", "source": "se_flat", "target": "se_reduce", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e10", "source": "se_reduce", "target": "se_act", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e11", "source": "se_act", "target": "se_expand", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e12", "source": "se_expand", "target": "se_sigmoid", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e13", "source": "se_sigmoid", "target": "se_unflat", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e14a", "source": "spatial_act", "target": "se_apply", "sourceHandle": "tensor", "targetHandle": "tensor_a" },
    { "id": "e14b", "source": "se_unflat", "target": "se_apply", "sourceHandle": "tensor", "targetHandle": "tensor_b" },

    { "id": "e15", "source": "se_apply", "target": "project", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e16", "source": "project", "target": "project_bn", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e17a", "source": "project_bn", "target": "skip_add", "sourceHandle": "tensor", "targetHandle": "tensor_a" },
    { "id": "e17b", "source": "input", "target": "skip_add", "sourceHandle": "tensor", "targetHandle": "tensor_b" },

    { "id": "e18", "source": "skip_add", "target": "head_pool", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e19", "source": "head_pool", "target": "head_flat", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e20", "source": "head_flat", "target": "head_fc", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e21", "source": "head_fc", "target": "print_logits", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
