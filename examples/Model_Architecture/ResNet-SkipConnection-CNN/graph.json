      "data": { "params": { "function": "relu" } }
    },
    {
      "id": "res2-conv1",
      "type": "Conv2d",
      "position": { "x": 50, "y": 700 },
      "data": { "params": { "in_channels": 128, "out_channels": 128, "kernel_size": 3, "stride": 1, "padding": 1 } }
    },
    {
