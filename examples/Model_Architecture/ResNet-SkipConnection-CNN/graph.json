{
  "name": "ResNet with Skip Connections",
  "description": "ResNet (Residual Network) — Still the backbone of most production CV systems. Demonstrates residual/skip connections using Concat nodes to merge the shortcut path with the main path, enabling training of very deep networks by solving the vanishing gradient problem.",
  "nodes": [
    {
      "id": "dataset-1",
      "type": "Dataset",
