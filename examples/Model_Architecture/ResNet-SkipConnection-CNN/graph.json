{
  "name": "ResNet with Skip Connections",
  "description": "Forward-pass visualization of a mini-ResNet on a sample CIFAR10-shaped batch. Each layer node executes on the real tensor flowing from TensorCreate, so you can see shapes at every stage. The Add nodes (b1_add, b2_add) make the residual shortcuts explicit on the canvas. Not a training graph — use the Usage_Example/ResNet-CIFAR10 version for training.",
  "nodes": [
    { "id": "start-1", "type": "Start", "position": { "x": -200, "y": 0 }, "data": { "params": {} } },

    { "id": "input", "type": "TensorCreate", "position": { "x": 0, "y": 0 }, "data": { "params": { "shape": "2,3,32,32", "fill": "randn", "value": 0.0, "requires_grad": false } } },

    { "id": "stem_conv", "type": "Conv2d", "position": { "x": 220, "y": 0 }, "data": { "params": { "in_channels": 3, "out_channels": 64, "kernel_size": 7, "stride": 2, "padding": 3 } } },
    { "id": "stem_bn", "type": "BatchNorm2d", "position": { "x": 440, "y": 0 }, "data": { "params": { "num_features": 64 } } },
    { "id": "stem_act", "type": "Activation", "position": { "x": 660, "y": 0 }, "data": { "params": { "function": "relu" } } },
    { "id": "stem_pool", "type": "MaxPool2d", "position": { "x": 880, "y": 0 }, "data": { "params": { "kernel_size": 3, "stride": 2 } } },

    { "id": "b1_c1", "type": "Conv2d", "position": { "x": 0, "y": 220 }, "data": { "params": { "in_channels": 64, "out_channels": 64, "kernel_size": 3, "stride": 1, "padding": 1 } } },
    { "id": "b1_bn1", "type": "BatchNorm2d", "position": { "x": 220, "y": 220 }, "data": { "params": { "num_features": 64 } } },
    { "id": "b1_act1", "type": "Activation", "position": { "x": 440, "y": 220 }, "data": { "params": { "function": "relu" } } },
    { "id": "b1_c2", "type": "Conv2d", "position": { "x": 660, "y": 220 }, "data": { "params": { "in_channels": 64, "out_channels": 64, "kernel_size": 3, "stride": 1, "padding": 1 } } },
    { "id": "b1_bn2", "type": "BatchNorm2d", "position": { "x": 880, "y": 220 }, "data": { "params": { "num_features": 64 } } },
    { "id": "b1_add", "type": "Add", "position": { "x": 1100, "y": 110 }, "data": { "params": { "alpha": 1.0 } } },
    { "id": "b1_act2", "type": "Activation", "position": { "x": 1320, "y": 110 }, "data": { "params": { "function": "relu" } } },

    { "id": "b2_c1", "type": "Conv2d", "position": { "x": 0, "y": 440 }, "data": { "params": { "in_channels": 64, "out_channels": 64, "kernel_size": 3, "stride": 1, "padding": 1 } } },
    { "id": "b2_bn1", "type": "BatchNorm2d", "position": { "x": 220, "y": 440 }, "data": { "params": { "num_features": 64 } } },
    { "id": "b2_act1", "type": "Activation", "position": { "x": 440, "y": 440 }, "data": { "params": { "function": "relu" } } },
    { "id": "b2_c2", "type": "Conv2d", "position": { "x": 660, "y": 440 }, "data": { "params": { "in_channels": 64, "out_channels": 64, "kernel_size": 3, "stride": 1, "padding": 1 } } },
    { "id": "b2_bn2", "type": "BatchNorm2d", "position": { "x": 880, "y": 440 }, "data": { "params": { "num_features": 64 } } },
    { "id": "b2_add", "type": "Add", "position": { "x": 1100, "y": 330 }, "data": { "params": { "alpha": 1.0 } } },
    { "id": "b2_act2", "type": "Activation", "position": { "x": 1320, "y": 330 }, "data": { "params": { "function": "relu" } } },

    { "id": "head_pool", "type": "AdaptiveAvgPool2d", "position": { "x": 1540, "y": 220 }, "data": { "params": { "output_height": 1, "output_width": 1 } } },
    { "id": "head_flat", "type": "Flatten", "position": { "x": 1760, "y": 220 }, "data": { "params": { "start_dim": 1 } } },
    { "id": "head_fc", "type": "Linear", "position": { "x": 1980, "y": 220 }, "data": { "params": { "in_features": 64, "out_features": 10 } } },
    { "id": "print_logits", "type": "Print", "position": { "x": 2200, "y": 220 }, "data": { "params": { "label": "Logits (B,10)" } } }
  ],
  "edges": [
    { "id": "e-trig-input", "source": "start-1", "target": "input", "sourceHandle": "trigger", "type": "trigger" },

    { "id": "e-input-stemconv", "source": "input", "target": "stem_conv", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-stemconv-stembn", "source": "stem_conv", "target": "stem_bn", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-stembn-stemact", "source": "stem_bn", "target": "stem_act", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-stemact-stempool", "source": "stem_act", "target": "stem_pool", "sourceHandle": "tensor", "targetHandle": "tensor" },

    { "id": "e-stempool-b1c1", "source": "stem_pool", "target": "b1_c1", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-b1c1-b1bn1", "source": "b1_c1", "target": "b1_bn1", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-b1bn1-b1act1", "source": "b1_bn1", "target": "b1_act1", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-b1act1-b1c2", "source": "b1_act1", "target": "b1_c2", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-b1c2-b1bn2", "source": "b1_c2", "target": "b1_bn2", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-b1bn2-b1add", "source": "b1_bn2", "target": "b1_add", "sourceHandle": "tensor", "targetHandle": "tensor_a" },
    { "id": "e-skip1-b1add", "source": "stem_pool", "target": "b1_add", "sourceHandle": "tensor", "targetHandle": "tensor_b" },
    { "id": "e-b1add-b1act2", "source": "b1_add", "target": "b1_act2", "sourceHandle": "tensor", "targetHandle": "tensor" },

    { "id": "e-b1act2-b2c1", "source": "b1_act2", "target": "b2_c1", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-b2c1-b2bn1", "source": "b2_c1", "target": "b2_bn1", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-b2bn1-b2act1", "source": "b2_bn1", "target": "b2_act1", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-b2act1-b2c2", "source": "b2_act1", "target": "b2_c2", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-b2c2-b2bn2", "source": "b2_c2", "target": "b2_bn2", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-b2bn2-b2add", "source": "b2_bn2", "target": "b2_add", "sourceHandle": "tensor", "targetHandle": "tensor_a" },
    { "id": "e-skip2-b2add", "source": "b1_act2", "target": "b2_add", "sourceHandle": "tensor", "targetHandle": "tensor_b" },
    { "id": "e-b2add-b2act2", "source": "b2_add", "target": "b2_act2", "sourceHandle": "tensor", "targetHandle": "tensor" },

    { "id": "e-b2act2-headpool", "source": "b2_act2", "target": "head_pool", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-headpool-flat", "source": "head_pool", "target": "head_flat", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-flat-fc", "source": "head_flat", "target": "head_fc", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-fc-print", "source": "head_fc", "target": "print_logits", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
