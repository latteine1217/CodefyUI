      "type": "Loss",
      "position": { "x": 50, "y": 1100 },
      "data": { "params": { "type": "CrossEntropyLoss" } }
    },
    {
      "id": "optimizer-1",
      "type": "Optimizer",
      "position": { "x": 350, "y": 1100 },
      "data": { "params": { "type": "SGD", "lr": 0.1, "weight_decay": 0.0001 } }
    },
    {
      "id": "visualize-1",
      "type": "Visualize",
      "position": { "x": 650, "y": 1100 },
      "data": { "params": { "title": "ResNet Training Curve", "plot_type": "line" } }
    }
