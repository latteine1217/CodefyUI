{
  "name": "ConvNeXt (Simplified)",
  "description": "Forward-pass visualization of a ConvNeXt-style block. ConvNeXt (FAIR, 2022) modernises a plain ResNet with four Transformer-inspired tweaks: (1) patchify stem (Conv 4x4 stride 4), (2) depthwise-style spatial mixing, (3) inverted-bottleneck 1x1 convs, (4) GELU activations. This demo uses a plain Conv2d instead of depthwise (not yet available as a primitive), so it's architecturally close but not bit-identical. Input (2,3,32,32) → stem (8x8 feature map) → one ConvNeXt block with residual → pool → Linear → 10 class logits.",
  "nodes": [
    { "id": "start-1", "type": "Start", "position": { "x": -200, "y": 0 }, "data": { "params": {} } },
    { "id": "input", "type": "TensorCreate", "position": { "x": 0, "y": 0 }, "data": { "params": { "shape": "2,3,32,32", "fill": "randn", "value": 0.0, "requires_grad": false } } },

    { "id": "stem_conv", "type": "Conv2d", "position": { "x": 220, "y": 0 }, "data": { "params": { "in_channels": 3, "out_channels": 96, "kernel_size": 4, "stride": 4, "padding": 0 } } },
    { "id": "stem_bn", "type": "BatchNorm2d", "position": { "x": 440, "y": 0 }, "data": { "params": { "num_features": 96 } } },

    { "id": "block_spatial", "type": "Conv2d", "position": { "x": 0, "y": 260 }, "data": { "params": { "in_channels": 96, "out_channels": 96, "kernel_size": 7, "stride": 1, "padding": 3 } } },
    { "id": "block_bn", "type": "BatchNorm2d", "position": { "x": 220, "y": 260 }, "data": { "params": { "num_features": 96 } } },
    { "id": "block_pw1", "type": "Conv2d", "position": { "x": 440, "y": 260 }, "data": { "params": { "in_channels": 96, "out_channels": 384, "kernel_size": 1, "stride": 1, "padding": 0 } } },
    { "id": "block_gelu", "type": "Activation", "position": { "x": 660, "y": 260 }, "data": { "params": { "function": "gelu" } } },
    { "id": "block_pw2", "type": "Conv2d", "position": { "x": 880, "y": 260 }, "data": { "params": { "in_channels": 384, "out_channels": 96, "kernel_size": 1, "stride": 1, "padding": 0 } } },
    { "id": "block_add", "type": "Add", "position": { "x": 1100, "y": 130 }, "data": { "params": { "alpha": 1.0 } } },

    { "id": "head_pool", "type": "AdaptiveAvgPool2d", "position": { "x": 1320, "y": 130 }, "data": { "params": { "output_height": 1, "output_width": 1 } } },
    { "id": "head_flat", "type": "Flatten", "position": { "x": 1540, "y": 130 }, "data": { "params": { "start_dim": 1 } } },
    { "id": "head_fc", "type": "Linear", "position": { "x": 1760, "y": 130 }, "data": { "params": { "in_features": 96, "out_features": 10 } } },
    { "id": "print_logits", "type": "Print", "position": { "x": 1980, "y": 130 }, "data": { "params": { "label": "Class logits (B,10)" } } }
  ],
  "edges": [
    { "id": "e-t", "source": "start-1", "target": "input", "sourceHandle": "trigger", "type": "trigger" },

    { "id": "e1", "source": "input", "target": "stem_conv", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e2", "source": "stem_conv", "target": "stem_bn", "sourceHandle": "tensor", "targetHandle": "tensor" },

    { "id": "e3", "source": "stem_bn", "target": "block_spatial", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e4", "source": "block_spatial", "target": "block_bn", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e5", "source": "block_bn", "target": "block_pw1", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e6", "source": "block_pw1", "target": "block_gelu", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e7", "source": "block_gelu", "target": "block_pw2", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e8a", "source": "block_pw2", "target": "block_add", "sourceHandle": "tensor", "targetHandle": "tensor_a" },
    { "id": "e8b", "source": "stem_bn", "target": "block_add", "sourceHandle": "tensor", "targetHandle": "tensor_b" },

    { "id": "e9", "source": "block_add", "target": "head_pool", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e10", "source": "head_pool", "target": "head_flat", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e11", "source": "head_flat", "target": "head_fc", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e12", "source": "head_fc", "target": "print_logits", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
