{
  "name": "BiGRU Speech Recognition",
  "description": "Forward-pass visualization of a Bidirectional GRU acoustic model. A mock mel-spectrogram batch (batch=2, seq=32 frames, features=40 mel bins) is fed into a 2-layer bidirectional GRU. Because bidirectional=true, the hidden dimension doubles to 128 at the output. A frame-wise Linear head projects to 50 phoneme classes per timestep — the standard front-end for CTC-based speech recognizers like DeepSpeech.",
  "nodes": [
    { "id": "start-1", "type": "Start", "position": { "x": -200, "y": 0 }, "data": { "params": {} } },
    { "id": "mel_input", "type": "TensorCreate", "position": { "x": 0, "y": 0 }, "data": { "params": { "shape": "2,32,40", "fill": "randn", "value": 0.0, "requires_grad": false } } },
    { "id": "bigru", "type": "GRU", "position": { "x": 240, "y": 0 }, "data": { "params": { "input_size": 40, "hidden_size": 64, "num_layers": 2, "batch_first": true, "bidirectional": true, "dropout": 0.0 } } },
    { "id": "frame_head", "type": "Linear", "position": { "x": 520, "y": 0 }, "data": { "params": { "in_features": 128, "out_features": 50 } } },
    { "id": "print_logits", "type": "Print", "position": { "x": 760, "y": 0 }, "data": { "params": { "label": "Frame logits (B,T,50)" } } }
  ],
  "edges": [
    { "id": "e-t", "source": "start-1", "target": "mel_input", "sourceHandle": "trigger", "type": "trigger" },
    { "id": "e1", "source": "mel_input", "target": "bigru", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e2", "source": "bigru", "target": "frame_head", "sourceHandle": "output", "targetHandle": "tensor" },
    { "id": "e3", "source": "frame_head", "target": "print_logits", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
