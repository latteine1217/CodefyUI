{
  "name": "LSTM Time-Series Forecaster",
  "description": "Forward-pass visualization of an LSTM time-series forecasting head. A batch of 24 past observations (batch=2, seq=24, features=1 — for example, hourly sensor readings) feeds into a 2-layer LSTM with hidden size 32. We take the full output sequence (B, 24, 32), Flatten to (B, 768), then project via Linear to a single scalar forecast per example. This is the classic 'lookback→predict-next' pattern used in weather, finance, and IoT forecasting.",
  "nodes": [
    { "id": "start-1", "type": "Start", "position": { "x": -200, "y": 0 }, "data": { "params": {} } },
    { "id": "history", "type": "TensorCreate", "position": { "x": 0, "y": 0 }, "data": { "params": { "shape": "2,24,1", "fill": "randn", "value": 0.0, "requires_grad": false } } },
    { "id": "lstm", "type": "LSTM", "position": { "x": 240, "y": 0 }, "data": { "params": { "input_size": 1, "hidden_size": 32, "num_layers": 2, "batch_first": true, "bidirectional": false, "dropout": 0.0 } } },
    { "id": "flat", "type": "Flatten", "position": { "x": 480, "y": 0 }, "data": { "params": { "start_dim": 1 } } },
    { "id": "predict", "type": "Linear", "position": { "x": 700, "y": 0 }, "data": { "params": { "in_features": 768, "out_features": 1 } } },
    { "id": "print_forecast", "type": "Print", "position": { "x": 920, "y": 0 }, "data": { "params": { "label": "Next-step forecast (B,1)" } } }
  ],
  "edges": [
    { "id": "e-t", "source": "start-1", "target": "history", "sourceHandle": "trigger", "type": "trigger" },
    { "id": "e1", "source": "history", "target": "lstm", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e2", "source": "lstm", "target": "flat", "sourceHandle": "output", "targetHandle": "tensor" },
    { "id": "e3", "source": "flat", "target": "predict", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e4", "source": "predict", "target": "print_forecast", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
