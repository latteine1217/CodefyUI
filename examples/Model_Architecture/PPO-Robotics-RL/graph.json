      "type": "Print",
      "position": { "x": 50, "y": 230 },
      "data": { "params": { "label": "Observation: 376-dim (joints + velocities + contacts)" } }
    },
    {
      "id": "ppo-1",
      "type": "PPO",
      "position": { "x": 400, "y": 50 },
      "data": { "params": { "state_dim": 376, "action_dim": 17, "hidden_dim": 256 } }
    },
    {
      "id": "optimizer-1",
      "type": "Optimizer",
