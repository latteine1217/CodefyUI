      "data": { "params": { "type": "AdamW", "lr": 0.0003, "weight_decay": 0.0 } }
    },
    {
      "id": "loss-policy",
      "type": "Loss",
      "position": { "x": 50, "y": 430 },
      "data": { "params": { "type": "MSELoss" } }
    },
    {
      "id": "print-action",
      "type": "Print",
      "position": { "x": 400, "y": 230 },
      "data": { "params": { "label": "Action: 17-dim continuous torques (Actor output)" } }
    },
    {
      "id": "print-value",
      "type": "Print",
      "position": { "x": 750, "y": 230 },
