    { "id": "e-2", "source": "env-1", "target": "print-obs", "sourceHandle": "observation", "targetHandle": "value" },
    { "id": "e-3", "source": "ppo-1", "target": "optimizer-1", "sourceHandle": "model", "targetHandle": "model" },
    { "id": "e-4", "source": "ppo-1", "target": "print-action", "sourceHandle": "action", "targetHandle": "value" }
