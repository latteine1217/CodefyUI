{
  "name": "LLaMA Decoder-Only Transformer",
  "description": "Forward-pass visualization of a LLaMA-style decoder-only transformer. Architecturally similar to GPT (causal self-attention, no encoder), but LLaMA's distinctive choice is pre-normalization: a LayerNorm (originally RMSNorm in the paper) is applied to the input before the attention stack. Input is a (seq=16, batch=2, d=32) token-embedding tensor. We pre-normalise, run the decoder with tensor=memory (self-attention only), post-normalise, pool, and project to 32 vocab logits.",
  "nodes": [
    { "id": "start-1", "type": "Start", "position": { "x": -200, "y": 0 }, "data": { "params": {} } },
    { "id": "input", "type": "TensorCreate", "position": { "x": 0, "y": 0 }, "data": { "params": { "shape": "16,2,32", "fill": "randn", "value": 0.0, "requires_grad": false } } },
    { "id": "pre_norm", "type": "LayerNorm", "position": { "x": 240, "y": 0 }, "data": { "params": { "normalized_shape": "32", "eps": 0.00001 } } },
    { "id": "decoder", "type": "TransformerDecoder", "position": { "x": 480, "y": 0 }, "data": { "params": { "d_model": 32, "nhead": 4, "num_layers": 4, "dim_feedforward": 128 } } },
    { "id": "post_norm", "type": "LayerNorm", "position": { "x": 760, "y": 0 }, "data": { "params": { "normalized_shape": "32", "eps": 0.00001 } } },
    { "id": "to_batch_first", "type": "Permute", "position": { "x": 1000, "y": 0 }, "data": { "params": { "dims": "1,0,2" } } },
    { "id": "last_token", "type": "Mean", "position": { "x": 1220, "y": 0 }, "data": { "params": { "dim": "1", "keepdim": false } } },
    { "id": "head", "type": "Linear", "position": { "x": 1440, "y": 0 }, "data": { "params": { "in_features": 32, "out_features": 32 } } },
    { "id": "print_logits", "type": "Print", "position": { "x": 1660, "y": 0 }, "data": { "params": { "label": "Next-token logits (B,V)" } } }
  ],
  "edges": [
    { "id": "e-t", "source": "start-1", "target": "input", "sourceHandle": "trigger", "type": "trigger" },
    { "id": "e1", "source": "input", "target": "pre_norm", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e2a", "source": "pre_norm", "target": "decoder", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e2b", "source": "pre_norm", "target": "decoder", "sourceHandle": "tensor", "targetHandle": "memory" },
    { "id": "e3", "source": "decoder", "target": "post_norm", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e4", "source": "post_norm", "target": "to_batch_first", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e5", "source": "to_batch_first", "target": "last_token", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e6", "source": "last_token", "target": "head", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e7", "source": "head", "target": "print_logits", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
