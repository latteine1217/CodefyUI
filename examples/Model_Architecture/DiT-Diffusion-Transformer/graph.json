{
  "name": "Diffusion Transformer (DiT)",
  "description": "Diffusion Transformer (Meta, 2023) — The architecture powering Stable Diffusion 3, FLUX, and Sora. Replaces U-Net with Transformer blocks for denoising diffusion. Processes noisy image patches through Transformer layers conditioned on timestep and class embeddings. State-of-the-art for image and video generation.",
  "nodes": [
    {
      "id": "dataset-1",
      "type": "Dataset",
      "position": { "x": 50, "y": 50 },
      "data": { "params": { "name": "CIFAR10", "split": "train", "data_dir": "./data" } }
    },
    {
      "id": "transform-1",
      "type": "Transform",
      "position": { "x": 350, "y": 50 },
      "data": { "params": { "resize": 32, "normalize": true, "to_tensor": true } }
    },
    {
      "id": "dataloader-1",
      "type": "DataLoader",
      "position": { "x": 650, "y": 50 },
      "data": { "params": { "batch_size": 64, "shuffle": true, "num_workers": 4 } }
    },
    {
      "id": "patch-embed",
      "type": "Conv2d",
      "position": { "x": 50, "y": 300 },
      "data": { "params": { "in_channels": 3, "out_channels": 512, "kernel_size": 4, "stride": 4, "padding": 0 } }
    },
    {
      "id": "reshape-patches",
      "type": "Reshape",
      "position": { "x": 350, "y": 300 },
      "data": { "params": { "shape": "-1,64,512" } }
    },
    {
      "id": "print-noisy",
      "type": "Print",
      "position": { "x": 350, "y": 460 },
      "data": { "params": { "label": "Noisy patches + timestep embedding + class label" } }
    },
    {
      "id": "dit-block-1",
      "type": "TransformerEncoder",
      "position": { "x": 700, "y": 300 },
      "data": { "params": { "d_model": 512, "nhead": 8, "num_layers": 6, "dim_feedforward": 2048 } }
    },
    {
      "id": "dit-block-2",
      "type": "TransformerEncoder",
      "position": { "x": 1050, "y": 300 },
      "data": { "params": { "d_model": 512, "nhead": 8, "num_layers": 6, "dim_feedforward": 2048 } }
    },
    {
      "id": "dropout-1",
      "type": "Dropout",
      "position": { "x": 1400, "y": 300 },
      "data": { "params": { "p": 0.1 } }
    },
    {
      "id": "reshape-img",
      "type": "Reshape",
      "position": { "x": 1400, "y": 460 },
      "data": { "params": { "shape": "-1,3,32,32" } }
    },
    {
      "id": "print-denoised",
      "type": "Print",
      "position": { "x": 1400, "y": 620 },
      "data": { "params": { "label": "Predicted noise ε (for denoising step)" } }
    },
    {
      "id": "loss-1",
      "type": "Loss",
      "position": { "x": 50, "y": 620 },
      "data": { "params": { "type": "MSELoss" } }
    },
    {
      "id": "optimizer-1",
      "type": "Optimizer",
      "position": { "x": 350, "y": 620 },
      "data": { "params": { "type": "AdamW", "lr": 0.0001, "weight_decay": 0.0 } }
    },
    {
      "id": "visualize-loss",
      "type": "Visualize",
      "position": { "x": 700, "y": 620 },
      "data": { "params": { "title": "Diffusion MSE Loss (noise prediction)", "plot_type": "line" } }
    },
    {
      "id": "visualize-samples",
      "type": "Visualize",
      "position": { "x": 1050, "y": 620 },
      "data": { "params": { "title": "Generated Samples (FID tracking)", "plot_type": "histogram" } }
    }
  ],
  "edges": [
    { "id": "e-1", "source": "dataset-1", "target": "transform-1", "sourceHandle": "dataset", "targetHandle": "dataset" },
    { "id": "e-2", "source": "transform-1", "target": "dataloader-1", "sourceHandle": "dataset", "targetHandle": "dataset" },
    { "id": "e-3", "source": "patch-embed", "target": "reshape-patches", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-4", "source": "reshape-patches", "target": "print-noisy", "sourceHandle": "tensor", "targetHandle": "value" },
    { "id": "e-5", "source": "reshape-patches", "target": "dit-block-1", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-6", "source": "dit-block-1", "target": "dit-block-2", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-7", "source": "dit-block-2", "target": "dropout-1", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-8", "source": "dropout-1", "target": "reshape-img", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-9", "source": "reshape-img", "target": "print-denoised", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
