{
  "name": "DiT Diffusion Transformer",
  "description": "Forward-pass visualization of a DiT (Diffusion Transformer) block — the backbone used by Stable Diffusion 3 and OpenAI Sora. A noisy image batch (2,4,8,8) is patch-embedded into 16 tokens of 64-dim via a stride-2 Conv2d, processed by a TransformerEncoder with self-attention across all image patches, then projected back to per-patch noise predictions via a Linear head. The key insight: the Transformer's global receptive field replaces the local U-Net in classical diffusion models.",
  "nodes": [
    { "id": "start-1", "type": "Start", "position": { "x": -200, "y": 0 }, "data": { "params": {} } },
    { "id": "noisy_latent", "type": "TensorCreate", "position": { "x": 0, "y": 0 }, "data": { "params": { "shape": "2,4,8,8", "fill": "randn", "value": 0.0, "requires_grad": false } } },
    { "id": "patch_embed", "type": "Conv2d", "position": { "x": 220, "y": 0 }, "data": { "params": { "in_channels": 4, "out_channels": 64, "kernel_size": 2, "stride": 2, "padding": 0 } } },
    { "id": "flatten_patches", "type": "Reshape", "position": { "x": 440, "y": 0 }, "data": { "params": { "shape": "2,64,16" } } },
    { "id": "to_seq_first", "type": "Permute", "position": { "x": 660, "y": 0 }, "data": { "params": { "dims": "2,0,1" } } },
    { "id": "dit_blocks", "type": "TransformerEncoder", "position": { "x": 920, "y": 0 }, "data": { "params": { "d_model": 64, "nhead": 8, "num_layers": 4, "dim_feedforward": 256 } } },
    { "id": "to_batch_first", "type": "Permute", "position": { "x": 1200, "y": 0 }, "data": { "params": { "dims": "1,0,2" } } },
    { "id": "noise_head", "type": "Linear", "position": { "x": 1420, "y": 0 }, "data": { "params": { "in_features": 64, "out_features": 64 } } },
    { "id": "print_eps", "type": "Print", "position": { "x": 1640, "y": 0 }, "data": { "params": { "label": "Predicted noise (B,N,D)" } } }
  ],
  "edges": [
    { "id": "e-t", "source": "start-1", "target": "noisy_latent", "sourceHandle": "trigger", "type": "trigger" },
    { "id": "e1", "source": "noisy_latent", "target": "patch_embed", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e2", "source": "patch_embed", "target": "flatten_patches", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e3", "source": "flatten_patches", "target": "to_seq_first", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e4", "source": "to_seq_first", "target": "dit_blocks", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e5", "source": "dit_blocks", "target": "to_batch_first", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e6", "source": "to_batch_first", "target": "noise_head", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e7", "source": "noise_head", "target": "print_eps", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
