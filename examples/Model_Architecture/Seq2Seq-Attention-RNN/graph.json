{
  "name": "Seq2Seq with Attention",
  "description": "Forward-pass visualization of the classic Bahdanau-style seq-to-seq with attention used in pre-Transformer neural machine translation. An encoder LSTM summarizes the source sequence (batch=2, src_len=10, d=16) into contextual states. A decoder LSTM generates target states (batch=2, tgt_len=8, d=16). MultiHeadAttention then lets each decoder step query the full encoder state sequence, producing context-aware hidden states which are projected to vocabulary logits (vocab=64 for illustration).",
  "nodes": [
    { "id": "start-1", "type": "Start", "position": { "x": -200, "y": 0 }, "data": { "params": {} } },

    { "id": "src_input", "type": "TensorCreate", "position": { "x": 0, "y": 0 }, "data": { "params": { "shape": "2,10,16", "fill": "randn", "value": 0.0, "requires_grad": false } } },
    { "id": "encoder_lstm", "type": "LSTM", "position": { "x": 240, "y": 0 }, "data": { "params": { "input_size": 16, "hidden_size": 32, "num_layers": 1, "batch_first": true, "bidirectional": false, "dropout": 0.0 } } },
    { "id": "enc_to_seq_first", "type": "Permute", "position": { "x": 480, "y": 0 }, "data": { "params": { "dims": "1,0,2" } } },

    { "id": "tgt_input", "type": "TensorCreate", "position": { "x": 0, "y": 260 }, "data": { "params": { "shape": "2,8,16", "fill": "randn", "value": 0.0, "requires_grad": false } } },
    { "id": "decoder_lstm", "type": "LSTM", "position": { "x": 240, "y": 260 }, "data": { "params": { "input_size": 16, "hidden_size": 32, "num_layers": 1, "batch_first": true, "bidirectional": false, "dropout": 0.0 } } },
    { "id": "dec_to_seq_first", "type": "Permute", "position": { "x": 480, "y": 260 }, "data": { "params": { "dims": "1,0,2" } } },

    { "id": "attention", "type": "MultiHeadAttention", "position": { "x": 760, "y": 130 }, "data": { "params": { "embed_dim": 32, "num_heads": 4, "dropout": 0.0, "batch_first": false } } },
    { "id": "to_batch_first", "type": "Permute", "position": { "x": 1040, "y": 130 }, "data": { "params": { "dims": "1,0,2" } } },
    { "id": "vocab_head", "type": "Linear", "position": { "x": 1260, "y": 130 }, "data": { "params": { "in_features": 32, "out_features": 64 } } },
    { "id": "print_logits", "type": "Print", "position": { "x": 1480, "y": 130 }, "data": { "params": { "label": "Decoder vocab logits (B,T,V)" } } }
  ],
  "edges": [
    { "id": "e-ts", "source": "start-1", "target": "src_input", "sourceHandle": "trigger", "type": "trigger" },
    { "id": "e-tt", "source": "start-1", "target": "tgt_input", "sourceHandle": "trigger", "type": "trigger" },

    { "id": "e1", "source": "src_input", "target": "encoder_lstm", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e2", "source": "encoder_lstm", "target": "enc_to_seq_first", "sourceHandle": "output", "targetHandle": "tensor" },

    { "id": "e3", "source": "tgt_input", "target": "decoder_lstm", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e4", "source": "decoder_lstm", "target": "dec_to_seq_first", "sourceHandle": "output", "targetHandle": "tensor" },

    { "id": "e5q", "source": "dec_to_seq_first", "target": "attention", "sourceHandle": "tensor", "targetHandle": "query" },
    { "id": "e5k", "source": "enc_to_seq_first", "target": "attention", "sourceHandle": "tensor", "targetHandle": "key" },
    { "id": "e5v", "source": "enc_to_seq_first", "target": "attention", "sourceHandle": "tensor", "targetHandle": "value" },

    { "id": "e6", "source": "attention", "target": "to_batch_first", "sourceHandle": "output", "targetHandle": "tensor" },
    { "id": "e7", "source": "to_batch_first", "target": "vocab_head", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e8", "source": "vocab_head", "target": "print_logits", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
