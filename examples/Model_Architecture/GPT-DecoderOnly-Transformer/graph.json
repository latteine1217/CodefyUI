{
  "name": "GPT Decoder-Only Transformer",
  "description": "Forward-pass visualization of a GPT-style decoder block on a sample (seq_len=16, batch=2, d_model=24) token-embedding tensor. The TransformerDecoder node wires its own tensor output back as memory (causal self-attention only — no encoder), which is the core of decoder-only LLMs like GPT, Claude, and LLaMA. Downstream: Permute to batch-first, Flatten, Dropout, and a Linear head projecting to 10 logits. Not a training graph — see Usage_Example/GPT-Mini for training.",
  "nodes": [
    { "id": "start-1", "type": "Start", "position": { "x": -200, "y": 0 }, "data": { "params": {} } },

    { "id": "input", "type": "TensorCreate", "position": { "x": 0, "y": 0 }, "data": { "params": { "shape": "16,2,24", "fill": "randn", "value": 0.0, "requires_grad": false } } },

    { "id": "decoder", "type": "TransformerDecoder", "position": { "x": 260, "y": 0 }, "data": { "params": { "d_model": 24, "nhead": 4, "num_layers": 4, "dim_feedforward": 96 } } },

    { "id": "to_batch_first", "type": "Permute", "position": { "x": 540, "y": 0 }, "data": { "params": { "dims": "1,0,2" } } },
    { "id": "flat", "type": "Flatten", "position": { "x": 760, "y": 0 }, "data": { "params": { "start_dim": 1 } } },
    { "id": "drop", "type": "Dropout", "position": { "x": 980, "y": 0 }, "data": { "params": { "p": 0.1 } } },
    { "id": "head", "type": "Linear", "position": { "x": 1200, "y": 0 }, "data": { "params": { "in_features": 384, "out_features": 10 } } },
    { "id": "print_logits", "type": "Print", "position": { "x": 1420, "y": 0 }, "data": { "params": { "label": "Logits (B,10)" } } }
  ],
  "edges": [
    { "id": "e-trig", "source": "start-1", "target": "input", "sourceHandle": "trigger", "type": "trigger" },

    { "id": "e-in-dec-tgt", "source": "input", "target": "decoder", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-in-dec-mem", "source": "input", "target": "decoder", "sourceHandle": "tensor", "targetHandle": "memory" },

    { "id": "e-dec-perm", "source": "decoder", "target": "to_batch_first", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-perm-flat", "source": "to_batch_first", "target": "flat", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-flat-drop", "source": "flat", "target": "drop", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-drop-head", "source": "drop", "target": "head", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-head-print", "source": "head", "target": "print_logits", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
