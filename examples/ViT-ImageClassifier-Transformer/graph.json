{
  "name": "Vision Transformer (ViT)",
  "description": "Vision Transformer (Google, 2020) — 'An Image is Worth 16x16 Words'. Splits images into 16×16 patches via Conv2d (acting as patch embedding), then processes the patch sequence with a Transformer Encoder. Demonstrated that pure Transformers can match or outperform CNNs on image classification when pre-trained on large datasets.",
  "nodes": [
    {
      "id": "dataset-1",
      "type": "Dataset",
      "position": { "x": 50, "y": 50 },
      "data": { "params": { "name": "CIFAR10", "split": "train", "data_dir": "./data" } }
    },
    {
      "id": "transform-1",
      "type": "Transform",
      "position": { "x": 350, "y": 50 },
      "data": { "params": { "resize": 224, "normalize": true, "to_tensor": true } }
    },
    {
      "id": "dataloader-1",
      "type": "DataLoader",
      "position": { "x": 650, "y": 50 },
      "data": { "params": { "batch_size": 64, "shuffle": true, "num_workers": 4 } }
    },
    {
      "id": "patch-embed",
      "type": "Conv2d",
      "position": { "x": 50, "y": 300 },
      "data": { "params": { "in_channels": 3, "out_channels": 768, "kernel_size": 16, "stride": 16, "padding": 0 } }
    },
    {
      "id": "reshape-seq",
      "type": "Reshape",
      "position": { "x": 350, "y": 300 },
      "data": { "params": { "shape": "-1,196,768" } }
    },
    {
      "id": "encoder-1",
      "type": "TransformerEncoder",
      "position": { "x": 650, "y": 300 },
      "data": { "params": { "d_model": 768, "nhead": 12, "num_layers": 12, "dim_feedforward": 3072 } }
    },
    {
      "id": "dropout-1",
      "type": "Dropout",
      "position": { "x": 950, "y": 300 },
      "data": { "params": { "p": 0.1 } }
    },
    {
      "id": "reshape-cls",
      "type": "Reshape",
      "position": { "x": 1250, "y": 300 },
      "data": { "params": { "shape": "-1,768" } }
    },
    {
      "id": "print-patches",
      "type": "Print",
      "position": { "x": 350, "y": 480 },
      "data": { "params": { "label": "Patch Embeddings (196 patches × 768 dim)" } }
    },
    {
      "id": "print-cls",
      "type": "Print",
      "position": { "x": 1250, "y": 480 },
      "data": { "params": { "label": "CLS Token → Classification Head" } }
    },
    {
      "id": "loss-1",
      "type": "Loss",
      "position": { "x": 50, "y": 560 },
      "data": { "params": { "type": "CrossEntropyLoss" } }
    },
    {
      "id": "optimizer-1",
      "type": "Optimizer",
      "position": { "x": 350, "y": 560 },
      "data": { "params": { "type": "AdamW", "lr": 0.0003, "weight_decay": 0.1 } }
    },
    {
      "id": "visualize-loss",
      "type": "Visualize",
      "position": { "x": 650, "y": 560 },
      "data": { "params": { "title": "ViT Training Loss", "plot_type": "line" } }
    },
    {
      "id": "visualize-attn",
      "type": "Visualize",
      "position": { "x": 950, "y": 560 },
      "data": { "params": { "title": "Attention Heatmap", "plot_type": "heatmap" } }
    }
  ],
  "edges": [
    { "id": "e-1", "source": "dataset-1", "target": "transform-1", "sourceHandle": "dataset", "targetHandle": "dataset" },
    { "id": "e-2", "source": "transform-1", "target": "dataloader-1", "sourceHandle": "dataset", "targetHandle": "dataset" },
    { "id": "e-3", "source": "patch-embed", "target": "reshape-seq", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-4", "source": "reshape-seq", "target": "encoder-1", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-5", "source": "encoder-1", "target": "dropout-1", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-6", "source": "dropout-1", "target": "reshape-cls", "sourceHandle": "tensor", "targetHandle": "tensor" },
    { "id": "e-7", "source": "reshape-seq", "target": "print-patches", "sourceHandle": "tensor", "targetHandle": "value" },
    { "id": "e-8", "source": "reshape-cls", "target": "print-cls", "sourceHandle": "tensor", "targetHandle": "value" }
  ]
}
