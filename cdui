#!/usr/bin/env bash
# cdui — CodefyUI launcher. Finds a Python interpreter and forwards args to dev.py.
# Usage: ./cdui <install|dev|stop|test|clean>
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 1. Prefer uv's managed Python (what install.sh sets up — no ephemeral env overhead)
if command -v uv >/dev/null 2>&1; then
  if UV_PY="$(uv python find 3.11 2>/dev/null)" && [[ -x "$UV_PY" ]]; then
    exec "$UV_PY" "$SCRIPT_DIR/scripts/dev.py" "$@"
  fi
  # uv present but no 3.11 yet — let uv run install/resolve on the fly
  exec uv run --python 3.11 python "$SCRIPT_DIR/scripts/dev.py" "$@"
fi

# 2. Fall back to system Python (dev install path)
for cmd in python3 python; do
  if command -v "$cmd" >/dev/null 2>&1; then
    exec "$cmd" "$SCRIPT_DIR/scripts/dev.py" "$@"
  fi
done

echo "Error: no Python interpreter found. Run install.sh first." >&2
exit 1
